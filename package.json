{
  "name": "claude-vscode-bridge",
  "displayName": "Claude Code - VS Code Bridge",
  "description": "Bridge your VS Code selections to Claude CLI in real time. Select code, ask Claude — it sees your selection automatically.",
  "version": "2.0.0",
  "publisher": "Daniel-Manea",
  "license": "MIT",
  "icon": "media/logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Daniel-Manea/claude-vscode-bridge"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "ai",
    "selection",
    "bridge",
    "terminal",
    "cli"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claude-bridge",
          "title": "Claude Bridge",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "claude-bridge": [
        {
          "id": "claude-bridge.dashboard",
          "name": "Dashboard",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "claude-bridge.clearSelection",
        "title": "Clear Selection",
        "category": "Claude Bridge"
      },
      {
        "command": "claude-bridge.setup",
        "title": "Setup Claude Code Integration",
        "category": "Claude Bridge"
      },
      {
        "command": "claude-bridge.preview",
        "title": "Preview Current Selection",
        "category": "Claude Bridge"
      },
      {
        "command": "claude-bridge.removeConfig",
        "title": "Remove Claude Code Configuration",
        "category": "Claude Bridge"
      },
      {
        "command": "claude-bridge.openSettings",
        "title": "Open Settings",
        "category": "Claude Bridge",
        "icon": "$(gear)"
      },
      {
        "command": "claude-bridge.exportPreset",
        "title": "Export Preset to JSON",
        "category": "Claude Bridge"
      },
      {
        "command": "claude-bridge.importPreset",
        "title": "Import Preset from JSON",
        "category": "Claude Bridge"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "claude-bridge.openSettings",
          "when": "view == claude-bridge.dashboard",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Claude Bridge",
      "properties": {
        "claudeBridge.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable the selection bridge"
        },
        "claudeBridge.contextInjection": {
          "type": "boolean",
          "default": true,
          "description": "Automatically inject selected code into Claude's context on every message"
        },
        "claudeBridge.statusLine": {
          "type": "boolean",
          "default": true,
          "description": "Show current selection in Claude CLI's status bar"
        },
        "claudeBridge.autoSetup": {
          "type": "boolean",
          "default": true,
          "description": "Automatically configure Claude Code settings.json on activation"
        },
        "claudeBridge.maxLines": {
          "type": "number",
          "default": 500,
          "minimum": 1,
          "maximum": 5000,
          "description": "Maximum number of selected lines to send to Claude (larger selections are truncated)"
        },
        "claudeBridge.debounceMs": {
          "type": "number",
          "default": 30,
          "minimum": 10,
          "maximum": 500,
          "description": "Debounce delay in milliseconds before writing selection to disk"
        },
        "claudeBridge.statusLineMaxPath": {
          "type": "number",
          "default": 30,
          "minimum": 10,
          "maximum": 100,
          "description": "Maximum path length in status line before truncation (only used when path style is 'truncated')"
        },
        "claudeBridge.statusLinePathStyle": {
          "type": "string",
          "default": "basename",
          "enum": ["basename", "truncated", "full"],
          "enumDescriptions": [
            "Show only the file name (e.g., file.ts)",
            "Show the relative path, truncated to Status Line Max Path (e.g., src/.../file.ts)",
            "Show the full relative path (e.g., src/components/file.ts)"
          ],
          "description": "How file paths are formatted in the Claude CLI status line and the VS Code status bar"
        },
        "claudeBridge.contextPrefix": {
          "type": "string",
          "default": "[VS Code Selection]",
          "description": "Prefix shown before the file path in context injection"
        },
        "claudeBridge.showPartialLineContext": {
          "type": "boolean",
          "default": true,
          "description": "For partial line selections, show the full line with caret markers"
        },
        "claudeBridge.statusLineSegments": {
          "type": "array",
          "default": [
            { "id": "model", "enabled": true },
            { "id": "gitBranch", "enabled": true },
            { "id": "contextBar", "enabled": true },
            { "id": "contextPercentage", "enabled": true },
            { "id": "cost", "enabled": false },
            { "id": "linesChanged", "enabled": false },
            { "id": "rateLimits", "enabled": false },
            { "id": "sessionDuration", "enabled": false },
            { "id": "selection", "enabled": true }
          ],
          "description": "Ordered list of status line segments. Edit via the Claude Bridge dashboard to reorder and toggle.",
          "items": {
            "type": "object",
            "required": ["id", "enabled"],
            "properties": {
              "id": {
                "type": "string",
                "enum": [
                  "model",
                  "gitBranch",
                  "contextBar",
                  "contextPercentage",
                  "cost",
                  "linesChanged",
                  "rateLimits",
                  "sessionDuration",
                  "selection"
                ]
              },
              "enabled": {
                "type": "boolean"
              }
            }
          }
        },
        "claudeBridge.activePreset": {
          "type": "string",
          "default": "default",
          "enum": ["minimal", "default", "powerUser", "costConscious", "custom"],
          "enumDescriptions": [
            "Just the essentials: selection only",
            "Balanced defaults: model, branch, context, selection",
            "Everything on: all segments enabled",
            "Adds cost and rate-limit visibility to the default preset",
            "Your own configuration (set automatically when you tweak)"
          ],
          "description": "Active preset. Picking a preset overwrites segment and behavior settings."
        },
        "claudeBridge.settingsTarget": {
          "type": "string",
          "default": "user",
          "enum": [
            "user",
            "project",
            "projectLocal",
            "ask"
          ],
          "enumDescriptions": [
            "~/.claude/settings.json — applies to all projects (recommended)",
            ".claude/settings.json — project only, shared via git with team",
            ".claude/settings.local.json — project only, gitignored",
            "Ask me every time"
          ],
          "description": "Where to write Claude Code configuration"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./ && tsc -p ./tsconfig.webview.json",
    "watch": "tsc -watch -p ./ & tsc -watch -p ./tsconfig.webview.json",
    "package": "npm run compile && vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  }
}
