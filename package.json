{
  "name": "claude-vscode-bridge",
  "displayName": "Claude Code - VS Code Bridge",
  "description": "Bridges your VS Code selection to Claude CLI in real time",
  "version": "1.0.2",
  "publisher": "Daniel-Manea",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Daniel-Manea/claude-vscode-bridge"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claude-bridge.clearSelection",
        "title": "Claude Bridge: Clear Selection"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  }
}
